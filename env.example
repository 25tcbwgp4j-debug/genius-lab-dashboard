# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (email)
RESEND_API_KEY=re_xxxx
EMAIL_FROM=noreply@geniuslab.it
EMAIL_FROM_ADDRESS=noreply@geniuslab.it
EMAIL_FROM_NAME=Genius Lab

# AI (OpenAI-compatible)
OPENAI_API_KEY=sk-xxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# WhatsApp (adapter: stub | twilio | meta)
# WHATSAPP_ADAPTER=stub
# WHATSAPP_API_URL=
# WHATSAPP_TOKEN=
# Webhook: set in production to verify callbacks. Meta: WHATSAPP_WEBHOOK_SECRET or META_APP_SECRET; Twilio: TWILIO_AUTH_TOKEN
# WHATSAPP_WEBHOOK_SECRET=
# TWILIO_AUTH_TOKEN=
# META_APP_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
